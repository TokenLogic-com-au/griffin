# sGHO Router Frontend - Environment Variables
# Copy to .env.local and fill in values

# WalletConnect Project ID (get one at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Contract Addresses (defaults to Ethereum Mainnet)
NEXT_PUBLIC_SGHO_ROUTER_ADDRESS=
NEXT_PUBLIC_GSM_ROUTER_ADDRESS=
NEXT_PUBLIC_SGHO_ADDRESS=
NEXT_PUBLIC_GHO_ADDRESS=0x40D16FC0246aD3160Ccc09B8D0D3A2cD28aE6C2f
NEXT_PUBLIC_USDC_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
NEXT_PUBLIC_USDT_ADDRESS=0xdAC17F958D2ee523a2206206994597C13D831ec7
NEXT_PUBLIC_GSM_USDC_ADDRESS=0xFeeb6FE430B7523fEF2a38327241eE7153779535
NEXT_PUBLIC_GSM_USDT_ADDRESS=0x535b2f7C20B9C83d70e519cf9991578eF9816B7B

# Chain ID (1 = Ethereum Mainnet, 31337 = Anvil local fork)
# In Tenderly mode, this must be a non-1 chain ID.
NEXT_PUBLIC_CHAIN_ID=1

# Anvil fork RPC (for local development)
NEXT_PUBLIC_ANVIL_RPC_URL=http://127.0.0.1:8545

# Tenderly Virtual TestNet (optional)
# Set NEXT_PUBLIC_TENDERLY_VNET_ENABLED=true to use a custom Tenderly chain in wagmi.
NEXT_PUBLIC_TENDERLY_VNET_ENABLED=false
NEXT_PUBLIC_TENDERLY_RPC_URL=
NEXT_PUBLIC_TENDERLY_CHAIN_NAME=Tenderly Virtual TestNet
NEXT_PUBLIC_TENDERLY_EXPLORER_URL=
NEXT_PUBLIC_TENDERLY_NATIVE_CURRENCY_NAME=Ether
NEXT_PUBLIC_TENDERLY_NATIVE_CURRENCY_SYMBOL=ETH

# Tenderly Admin RPC URL (server-side only, used by /api/faucet)
TENDERLY_ADMIN_RPC_URL=
